<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_report_pesaje_wizard_form" model="ir.ui.view">
        <field name="name">pesaje.report.wizard.form</field>
        <field name="model">pesaje.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Reporte">
                <group>
                    <field name="report_type"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <group string="Filtros opcionales">
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="product_id"/>
                </group>
                <footer>
                    <button name="action_print_report" string="Generar PDF" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_report_pesaje_wizard" model="ir.actions.act_window">
        <field name="name">Generar Reporte</field>
        <field name="res_model">pesaje.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

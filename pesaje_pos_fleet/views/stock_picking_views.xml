<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_pesaje" model="ir.ui.view">
        <field name="name">stock.picking.form.pesaje</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_create_pesaje_despacho" type="object"
                        class="oe_stat_button" icon="fa-balance-scale"
                        invisible="picking_type_code != 'outgoing'">
                    <field name="pesaje_count" widget="statinfo" string="Pesaje"/>
                </button>
            </div>
        </field>
    </record>
</odoo>

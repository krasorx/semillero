<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pesaje_hibrido_list" model="ir.ui.view">
        <field name="name">pesaje.hibrido.list</field>
        <field name="model">pesaje.hibrido</field>
        <field name="arch" type="xml">
            <list string="Híbridos" editable="bottom">
                <field name="name"/>
                <field name="product_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_pesaje_hibrido" model="ir.actions.act_window">
        <field name="name">Híbridos</field>
        <field name="res_model">pesaje.hibrido</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

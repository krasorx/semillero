<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Consulta de todos los pesajes (sin filtro operativo en_planta) -->
    <record id="action_pesaje_consulta" model="ir.actions.act_window">
        <field name="name">Pesajes</field>
        <field name="res_model">pesaje.pesaje</field>
        <field name="view_mode">list,kanban,pivot,graph,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay pesajes registrados</p>
            <p>Acá podés consultar y editar todos los registros de pesaje.</p>
        </field>
    </record>

    <!-- Dashboard: vistas nativas de análisis (pivot/graph) -->
    <record id="action_pesaje_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">pesaje.pesaje</field>
        <field name="view_mode">graph,pivot,kanban,list</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pesaje_tara_list" model="ir.ui.view">
        <field name="name">pesaje.tara.list</field>
        <field name="model">pesaje.tara</field>
        <field name="arch" type="xml">
            <list string="Taras" decoration-info="tipo=='entrada'">
                <field name="datetime"/>
                <field name="pesaje_id"/>
                <field name="tipo" widget="badge"/>
                <field name="peso"/>
                <field name="employee_id"/>
            </list>
        </field>
    </record>

    <record id="view_pesaje_tara_form" model="ir.ui.view">
        <field name="name">pesaje.tara.form</field>
        <field name="model">pesaje.tara</field>
        <field name="arch" type="xml">
            <form string="Tara">
                <sheet>
                    <group>
                        <group>
                            <field name="pesaje_id"/>
                            <field name="tipo"/>
                        </group>
                        <group>
                            <field name="peso"/>
                            <field name="datetime"/>
                            <field name="employee_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pesaje_tara_search" model="ir.ui.view">
        <field name="name">pesaje.tara.search</field>
        <field name="model">pesaje.tara</field>
        <field name="arch" type="xml">
            <search string="Taras">
                <field name="pesaje_id"/>
                <field name="employee_id"/>
                <filter string="Entrada" name="tipo_entrada" domain="[('tipo','=','entrada')]"/>
                <filter string="Salida" name="tipo_salida" domain="[('tipo','=','salida')]"/>
                <separator/>
                <filter string="Por Tipo" name="group_tipo" context="{'group_by':'tipo'}"/>
                <filter string="Por Pesaje" name="group_pesaje" context="{'group_by':'pesaje_id'}"/>
                <filter string="Por Operador" name="group_employee" context="{'group_by':'employee_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_pesaje_tara" model="ir.actions.act_window">
        <field name="name">Taras</field>
        <field name="res_model">pesaje.tara</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

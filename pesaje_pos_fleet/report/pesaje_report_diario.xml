<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_pesaje_diario">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="pesajes" t-value="o._get_pesajes()"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="text-align:center; border-bottom:2px solid #333; padding-bottom:10px; margin-bottom:16px;">
                            <h2 style="margin:0;">REPORTE DIARIO DE PESAJES</h2>
                            <p style="margin:4px 0 0; color:#555; font-size:13px;">
                                Período: <t t-esc="o.date_from"/> al <t t-esc="o.date_to"/>
                            </p>
                        </div>

                        <!-- Resumen por producto -->
                        <h3 style="font-size:14px; margin-bottom:8px;">Resumen por Material</h3>
                        <t t-set="by_product" t-value="{}"/>
                        <t t-foreach="pesajes" t-as="p">
                            <t t-set="key" t-value="p.product_id.display_name or 'Sin material'"/>
                            <t t-if="key not in by_product" t-set="by_product" t-value="{**by_product, key: {'count': 0, 'neto': 0.0, 'bruto': 0.0}}"/>
                            <t t-set="by_product" t-value="{**by_product, key: {'count': by_product[key]['count'] + 1, 'neto': by_product[key]['neto'] + p.net_weight, 'bruto': by_product[key]['bruto'] + p.gross_weight}}"/>
                        </t>

                        <table style="width:100%; border-collapse:collapse; font-size:12px; margin-bottom:20px;">
                            <thead>
                                <tr style="background:#333; color:white;">
                                    <th style="padding:7px 10px; text-align:left;">Material</th>
                                    <th style="padding:7px 10px; text-align:right;">Cant.</th>
                                    <th style="padding:7px 10px; text-align:right;">Bruto Total (kg)</th>
                                    <th style="padding:7px 10px; text-align:right;">Neto Total (kg)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="by_product.items()" t-as="item">
                                    <tr t-att-style="'background:#f9f9f9;' if item_index % 2 == 0 else ''">
                                        <td style="padding:6px 10px;"><t t-esc="item[0]"/></td>
                                        <td style="padding:6px 10px; text-align:right;"><t t-esc="item[1]['count']"/></td>
                                        <td style="padding:6px 10px; text-align:right;"><t t-esc="'%.2f' % item[1]['bruto']"/></td>
                                        <td style="padding:6px 10px; text-align:right; font-weight:bold;"><t t-esc="'%.2f' % item[1]['neto']"/></td>
                                    </tr>
                                </t>
                                <tr style="background:#e8f5e9; font-weight:bold; border-top:2px solid #333;">
                                    <td style="padding:7px 10px;">TOTAL</td>
                                    <td style="padding:7px 10px; text-align:right;"><t t-esc="len(pesajes)"/></td>
                                    <td style="padding:7px 10px; text-align:right;"><t t-esc="'%.2f' % sum(pesajes.mapped('gross_weight'))"/></td>
                                    <td style="padding:7px 10px; text-align:right;"><t t-esc="'%.2f' % sum(pesajes.mapped('net_weight'))"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Detalle completo -->
                        <h3 style="font-size:14px; margin-bottom:8px;">Detalle de Pesajes</h3>
                        <table style="width:100%; border-collapse:collapse; font-size:11px;">
                            <thead>
                                <tr style="background:#555; color:white;">
                                    <th style="padding:6px 8px; text-align:left;">Ref.</th>
                                    <th style="padding:6px 8px; text-align:left;">Camión</th>
                                    <th style="padding:6px 8px; text-align:left;">Chófer</th>
                                    <th style="padding:6px 8px; text-align:left;">Material</th>
                                    <th style="padding:6px 8px; text-align:right;">Bruto</th>
                                    <th style="padding:6px 8px; text-align:right;">Neto</th>
                                    <th style="padding:6px 8px; text-align:center;">Salida</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="pesajes" t-as="p">
                                    <tr t-att-style="'background:#f9f9f9;' if p_index % 2 == 0 else ''">
                                        <td style="padding:5px 8px;"><t t-esc="p.name"/></td>
                                        <td style="padding:5px 8px;"><t t-esc="p.vehicle_id.license_plate or p.vehicle_id.display_name"/></td>
                                        <td style="padding:5px 8px;"><t t-esc="p.driver_id.name or '—'"/></td>
                                        <td style="padding:5px 8px;"><t t-esc="p.product_id.display_name or '—'"/></td>
                                        <td style="padding:5px 8px; text-align:right;"><t t-esc="'%.0f' % p.gross_weight"/></td>
                                        <td style="padding:5px 8px; text-align:right; font-weight:bold;"><t t-esc="'%.0f' % p.net_weight"/></td>
                                        <td style="padding:5px 8px; text-align:center;"><t t-esc="p.exit_datetime and p.exit_datetime.strftime('%H:%M') or '—'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

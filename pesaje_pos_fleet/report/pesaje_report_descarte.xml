<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_pesaje_descarte">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="pesajes" t-value="o._get_pesajes()"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="text-align:center; border-bottom:2px solid #c00; padding-bottom:10px; margin-bottom:16px;">
                            <h2 style="margin:0; color:#c00;">REPORTE DE DESCARTES</h2>
                            <p style="margin:4px 0 0; color:#555; font-size:13px;">
                                Período: <t t-esc="o.date_from"/> al <t t-esc="o.date_to"/>
                            </p>
                        </div>

                        <div style="background:#fff3f3; border:1px solid #fcc; padding:10px; border-radius:4px; margin-bottom:16px; font-size:12px;">
                            <strong>Total descartes:</strong> <t t-esc="len(pesajes)"/> pesajes —
                            <strong>Neto total descartado:</strong> <t t-esc="'%.2f' % sum(pesajes.mapped('net_weight'))"/> kg
                        </div>

                        <table style="width:100%; border-collapse:collapse; font-size:11px;">
                            <thead>
                                <tr style="background:#c00; color:white;">
                                    <th style="padding:6px 10px; text-align:left;">Ref.</th>
                                    <th style="padding:6px 10px; text-align:left;">Camión</th>
                                    <th style="padding:6px 10px; text-align:left;">Chófer</th>
                                    <th style="padding:6px 10px; text-align:left;">Material</th>
                                    <th style="padding:6px 10px; text-align:left;">Campo / Híbrido</th>
                                    <th style="padding:6px 10px; text-align:right;">Neto (kg)</th>
                                    <th style="padding:6px 10px; text-align:center;">Fecha</th>
                                    <th style="padding:6px 10px; text-align:left;">Observaciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="pesajes" t-as="p">
                                    <tr t-att-style="'background:#f9f9f9;' if p_index % 2 == 0 else ''">
                                        <td style="padding:5px 10px;"><t t-esc="p.name"/></td>
                                        <td style="padding:5px 10px;"><t t-esc="p.vehicle_id.license_plate or '—'"/></td>
                                        <td style="padding:5px 10px;"><t t-esc="p.driver_id.name or '—'"/></td>
                                        <td style="padding:5px 10px;"><t t-esc="p.product_id.display_name or '—'"/></td>
                                        <td style="padding:5px 10px;">
                                            <t t-esc="p.campo_id.name or '—'"/>
                                            <t t-if="p.hibrido_id"> / <t t-esc="p.hibrido_id.name"/></t>
                                        </td>
                                        <td style="padding:5px 10px; text-align:right; font-weight:bold; color:#c00;"><t t-esc="'%.2f' % p.net_weight"/></td>
                                        <td style="padding:5px 10px; text-align:center;"><t t-esc="p.exit_datetime and p.exit_datetime.strftime('%d/%m/%Y') or '—'"/></td>
                                        <td style="padding:5px 10px; font-size:10px;"><t t-esc="p.notes or '—'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
